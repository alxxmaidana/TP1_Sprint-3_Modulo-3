{
	"dependencies": {
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"mongoose": "^9.3.0"
	},
	"type": "module",
	"scripts": {
		"lint": "biome lint --write",
		"formar": "npx @biomejs/biome format --write",
		"check": "biome check --write",
		"ci": "biome ci ./src",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.9",
		"husky": "^9.1.7",
		"lint-staged": "^16.4.0"
	},
	"lint-staged": {
		"*.{js,jsx,ts,tsx,json}": [
			"biome check --write --no-errors-on-unmatched"
		]
	}
}
